{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler", // Or "Node" if not using Vite
    "strict": true,                // 🟢 Essential for Pinia type inference
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,          // 🟢 Speeds up build and ignores library type conflicts
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]          // Ensure your paths match your project structure
    },
    "types": ["pinia"]             // 🟢 Explicitly include pinia types
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "exclude": ["node_modules"]
}